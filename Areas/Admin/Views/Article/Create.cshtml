@model Article
@{
    ViewData["Title"] = "Thêm tin tức";
}
<form asp-area="Admin" asp-controller="Article" asp-action="Create" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label">Tiêu đề</label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Chuyên mục</label>
            <input asp-for="Category" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Ảnh</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
        </div>
        <div class="col-12">
            <label class="form-label">Nội dung</label>
            <textarea asp-for="Content" class="form-control" rows="8"></textarea>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Lưu</button>
            <a asp-area="Admin" asp-controller="Article" asp-action="Index" class="btn btn-secondary">Hủy</a>
        </div>
    </div>
</form>
