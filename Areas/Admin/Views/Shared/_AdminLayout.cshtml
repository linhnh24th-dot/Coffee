<!doctype html>
<html lang="vi">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>HyliCoffee Admin - @ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fontsource/source-sans-3@5.0.12/index.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.10.1/styles/overlayscrollbars.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />

    <!-- AdminLTE CSS gốc, giữ nguyên 100% -->
    <link rel="stylesheet" href="~/admin/css/adminlte.css" />
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <div class="app-wrapper">
        <!--begin::Header-->
        <nav class="app-header navbar navbar-expand bg-body">
            <div class="container-fluid">
                <ul class="navbar-nav w-100 d-flex justify-content-between">
                    <!-- Nhóm nút bên trái -->
                    <div class="d-flex">
                    <li class="nav-item">
                        <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                            <i class="bi bi-list"></i>
                        </a>
                    </li>
                    <!-- NÚT XEM TRANG CHỦ ĐƯỢC THÊM Ở ĐÂY -->
                    <li class="nav-item">
                        <a class="nav-link text-success" asp-area="" asp-controller="Home" asp-action="Index" target="_blank" title="Xem ngoài trang chủ">
                            <i class="bi bi-house-door-fill"></i>
                            <span class="d-none d-md-inline fw-bold"> Xem trang chủ</span>
                        </a>
                    </li>
            </div>

            <!-- Nhóm nút bên phải (Đăng xuất) -->
            <li class="nav-item">
                <a class="nav-link text-danger" asp-area="" asp-controller="Account" asp-action="Logout" title="Đăng xuất hệ thống">
                    <i class="bi bi-box-arrow-right"></i>
                    <span class="d-none d-md-inline"> Đăng xuất (@User.FindFirst("FullName")?.Value)</span>
                </a>
            </li>
            </ul>
    </div>
    </nav>
    <!--end::Header-->
    <!--begin::Sidebar-->
    <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
        <div class="sidebar-brand">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="brand-link">
                <span class="brand-text fw-light px-3">HyliCoffee Admin</span>
            </a>
        </div>
        <div class="sidebar-wrapper">
            <nav class="mt-2">
                <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="menu">
                    <li class="nav-item">
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link">
                            <i class="nav-icon bi bi-speedometer"></i><p>Dashboard</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="nav-link">
                            <i class="nav-icon bi bi-cup-hot"></i><p>Sản phẩm</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Admin" asp-controller="Article" asp-action="Index" class="nav-link">
                            <i class="nav-icon bi bi-newspaper"></i><p>Tin tức</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="nav-link">
                            <i class="nav-icon bi bi-receipt"></i><p>Đơn hàng</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Admin" asp-controller="Staff" asp-action="Index" class="nav-link">
                            <i class="nav-icon bi bi-people"></i><p>Nhân viên</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Admin" asp-controller="UserMgmt" asp-action="Index" class="nav-link">
                            <i class="nav-icon bi bi-person-badge"></i><p>Tài khoản</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Admin" asp-controller="Feedback" asp-action="Index" class="nav-link">
                            <i class="nav-icon bi bi-chat-dots"></i><p>Phản hồi khách hàng</p>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </aside>
    <!--end::Sidebar-->

    <main class="app-main">
        <div class="app-content-header">
            <div class="container-fluid">
                <h3>@ViewData["Title"]</h3>
            </div>
        </div>
        <div class="app-content">
            <div class="container-fluid">
                @if (TempData["SuccessMessage"] != null)
                {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }
                @RenderBody()
            </div>
        </div>
    </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.10.1/browser/overlayscrollbars.browser.es6.min.js" crossorigin="anonymous"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js"></script>
    <!-- AdminLTE JS gốc, giữ nguyên 100% -->
    <script src="~/admin/js/adminlte.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
