@model IEnumerable<HyliCoffeeWeb.Models.Article>

    @{
    ViewData["Title"] = "Tin tức";
    }

    <!-- Tiêu đề trang -->
    <div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
        <div class="container py-5">
            <h1 class="display-3 text-white animated slideInRight">Tin tức</h1>
            <nav aria-label="breadcrumb animated slideInRight">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Tin tức</li>
                </ol>
            </nav>
        </div>
    </div>
        <!-- Danh sách tin tức dạng Card -->
    <div class="container-xxl py-5">
        <div class="container">
            <div class="section-title text-center mx-auto" style="max-width: 500px;">
                <p class="fs-5 fw-medium fst-italic text-primary">Hyli Blog</p>
                <h1 class="display-6">Tin tức mới nhất từ HyliCoffee</h1>
            </div>

            <div class="row g-4 mt-4">
                @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                    <div class="card h-100 shadow-sm border-0">
                        <!-- Ảnh bài viết -->
                        @if (!string.IsNullOrEmpty(item.Image))
                            {
                        <img class="card-img-top" src="~/img/@item.Image" alt="@item.Title" style="height: 220px; object-fit: cover;">
                            }
                            else
                            {
                        <img class="card-img-top" src="~/img/cafe.jpg" alt="@item.Title" style="height: 220px; object-fit: cover;">
                            }

                        <div class="card-body p-4 d-flex flex-column">
                            <!-- Chuyên mục và Ngày đăng -->
                            <div class="text-muted small mb-2">
                                <span class="badge bg-primary me-2">@item.Category</span>
                                <i class="bi bi-calendar3 me-1"></i> @item.CreatedDate.ToString("dd/MM/yyyy")
                            </div>

                            <!-- Tiêu đề bài viết -->
                            <h5 class="card-title fw-bold mb-3 text-dark">@item.Title</h5>

                            <!-- Nội dung bài viết ngắn gọn -->
                            <p class="card-text text-muted flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                @item.Content
                            </p>
                        </div>
                    </div>
                </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted fs-5">Hiện chưa có tin tức nào được đăng tải.</p>
                </div>
            }
            </div>
        </div>
    </div>
