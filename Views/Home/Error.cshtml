@{
    ViewData["Title"] = "Lỗi";
    int? code      = ViewBag.StatusCode as int?;
    string reqId   = ViewBag.RequestId as string ?? "";
}
<div class="container-xxl py-5 text-center">
    @if (code == 404)
    {
        <h1 class="display-1 text-primary">404</h1>
        <h2 class="mb-4">Trang không tìm thấy</h2>
        <p class="text-muted mb-4">Đường dẫn bạn truy cập không tồn tại hoặc đã bị xóa.</p>
    }
    else if (code == 403)
    {
        <h1 class="display-1 text-danger">403</h1>
        <h2 class="mb-4">Không có quyền truy cập</h2>
        <p class="text-muted mb-4">Bạn không có quyền xem trang này.</p>
    }
    else
    {
        <h1 class="display-1 text-danger">@(code?.ToString() ?? "Lỗi")</h1>
        <h2 class="mb-4">Đã có lỗi xảy ra</h2>
        <p class="text-muted mb-4">Vui lòng thử lại hoặc liên hệ quản trị viên.</p>
    }
    @if (!string.IsNullOrEmpty(reqId))
    {
        <p class="text-muted small">Request ID: <code>@reqId</code></p>
    }
    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-5 py-3">
        <i class="fa fa-home me-2"></i>Về trang chủ
    </a>
</div>
