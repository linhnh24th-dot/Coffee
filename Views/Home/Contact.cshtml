@model Feedback
@{
    ViewData["Title"] = "Liên hệ";
}

<!-- Page Header Start -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container py-5">
        <h1 class="display-3 text-white animated slideInRight">Liên hệ</h1>
        <nav aria-label="breadcrumb animated slideInRight">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Liên hệ</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<div class="container-xxl py-5">
    <div class="container">
        <div class="section-title text-center mx-auto wow fadeInUp" style="max-width: 500px;">
            <p class="fs-5 fw-medium fst-italic text-primary">Contact Us</p>
            <h1 class="display-6">Liên hệ với chúng tôi</h1>
        </div>
        <div class="row g-5 justify-content-center mt-2">
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                <div class="d-flex flex-column align-items-center bg-light rounded p-4 h-100">
                    <div class="btn btn-square btn-primary rounded-circle mb-3" style="width: 64px; height: 64px;">
                        <i class="fa fa-map-marker-alt fa-2x"></i>
                    </div>
                    <h5>Địa chỉ</h5>
                    <p class="text-center mb-0">123 Đường Cà Phê, Quận 1, TP.HCM</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.2s">
                <div class="d-flex flex-column align-items-center bg-light rounded p-4 h-100">
                    <div class="btn btn-square btn-primary rounded-circle mb-3" style="width: 64px; height: 64px;">
                        <i class="fa fa-phone-alt fa-2x"></i>
                    </div>
                    <h5>Điện thoại</h5>
                    <p class="text-center mb-0">0999 686 822</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                <div class="d-flex flex-column align-items-center bg-light rounded p-4 h-100">
                    <div class="btn btn-square btn-primary rounded-circle mb-3" style="width: 64px; height: 64px;">
                        <i class="fa fa-envelope fa-2x"></i>
                    </div>
                    <h5>Email</h5>
                    <p class="text-center mb-0">contact@hylicoffee.vn</p>
                </div>
            </div>

            <div class="col-lg-8 wow fadeInUp" data-wow-delay="0.4s">
                <form asp-area="" asp-controller="Home" asp-action="Contact" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Name" class="form-control" placeholder="Tên của bạn">
                                <label asp-for="Name">Tên của bạn</label>
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Email" class="form-control" placeholder="Email">
                                <label asp-for="Email">Email của bạn</label>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <textarea asp-for="Content" class="form-control" placeholder="Nội dung" style="height: 150px"></textarea>
                                <label asp-for="Content">Nội dung</label>
                                <span asp-validation-for="Content" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-12 text-center">
                            <button class="btn btn-primary rounded-pill py-3 px-5" type="submit">
                                <i class="fa fa-paper-plane me-2"></i>Gửi liên hệ
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
