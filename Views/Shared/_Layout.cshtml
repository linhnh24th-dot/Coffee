<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <title>@ViewData["Title"] - HyliCoffee</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Template Libraries -->
    <link href="~/lib/animate/animate.min.css" rel="stylesheet">
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">

    <!-- Bootstrap (giữ nguyên file gốc của template) -->
    <link href="~/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Style (giữ nguyên 100%) -->
    <link href="~/css/style.css" rel="stylesheet">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Spinner -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
    </div>

    <!-- Navbar -->
    <partial name="_Menu" />

    <!-- Alert messages -->
    @if (TempData["SuccessMessage"] != null)
    {
    <div class="container-fluid p-0">
        <div class="alert alert-success text-center m-0 rounded-0 py-2">
            <i class="fa fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        </div>
    </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
    <div class="container-fluid p-0">
        <div class="alert alert-danger text-center m-0 rounded-0 py-2">
            <i class="fa fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        </div>
    </div>
    }

    @RenderBody()

    <!-- Footer -->
    <partial name="_Footer" />

    <!-- Cart Offcanvas -->
    <partial name="_CartModal" />

    <!-- JavaScript -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/wow/wow.min.js"></script>
    <script src="~/lib/easing/easing.min.js"></script>
    <script src="~/lib/waypoints/waypoints.min.js"></script>
    <script src="~/lib/owlcarousel/owl.carousel.min.js"></script>

    <!-- Template JS (giữ nguyên 100%) -->
    <script src="~/js/main.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        (function () { if (!window.chatbase || window.chatbase("getState") !== "initialized") { window.chatbase = (...arguments) => { if (!window.chatbase.q) { window.chatbase.q = [] } window.chatbase.q.push(arguments) }; window.chatbase = new Proxy(window.chatbase, { get(target, prop) { if (prop === "q") { return target.q } return (...args) => target(prop, ...args) } }) } const onLoad = function () { const script = document.createElement("script"); script.src = "https://www.chatbase.co/embed.min.js"; script.id = "kOippiXx9QYQyufmxT1uZ"; script.domain = "www.chatbase.co"; document.body.appendChild(script) }; if (document.readyState === "complete") { onLoad() } else { window.addEventListener("load", onLoad) } })();
    </script>
</body>
</html>
