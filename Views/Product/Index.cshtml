@model List<Product>
@{
    ViewData["Title"] = "Sản phẩm";
    var types = ViewBag.Types as List<string?> ?? new List<string?>();
    string currentType = ViewBag.Type as string ?? "";
    string currentKeyword = ViewBag.Keyword as string ?? "";
}

<!-- Page Header -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container py-5">
        <h1 class="display-3 text-white animated slideInRight">Sản phẩm</h1>
        <nav aria-label="breadcrumb animated slideInRight">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item active">Sản phẩm</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-xxl py-5">
    <div class="container">
        <!-- Form tìm kiếm & lọc -->
        <form asp-area="" asp-controller="Product" asp-action="Index" method="get" class="row g-3 mb-5 justify-content-center wow fadeInUp">
            <div class="col-md-4">
                <input type="text" name="keyword" value="@currentKeyword"
                       class="form-control py-3" placeholder="🔍 Tìm kiếm sản phẩm...">
            </div>
            <div class="col-md-3">
                <select name="type" class="form-select py-3">
                    <option value="">-- Tất cả loại --</option>
                    @foreach (var t in types)
                    {
                        if (t != null)
                        {
                            <option value="@t" selected="@(t == currentType ? "selected" : null)">@t</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill">Lọc</button>
            </div>
            @if (!string.IsNullOrEmpty(currentKeyword) || !string.IsNullOrEmpty(currentType))
            {
                <div class="col-md-1">
                    <a asp-area="" asp-controller="Product" asp-action="Index"
                       class="btn btn-outline-secondary w-100 py-3 rounded-pill">✕</a>
                </div>
            }
        </form>

        <!-- Danh sách sản phẩm -->
        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                foreach (var p in Model)
                {
                    <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <a asp-area="" asp-controller="Product" asp-action="Details" asp-route-id="@p.Id"
                           class="d-block product-item rounded text-decoration-none">
                            <img src="~/img/@(p.Image ?? "cfden.jpg")" class="img-fluid" alt="@p.Name"
                                 style="width: 100%; height: 220px; object-fit: cover;">
                            <div class="bg-white shadow-sm text-center p-4 position-relative mt-n5 mx-4">
                                <small class="badge bg-secondary mb-1">@p.Type</small>
                                <h5 class="text-dark">@p.Name</h5>
                                <h5 class="text-primary">@p.Price.ToString("N0") VND</h5>
                            </div>
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5 text-muted">
                    <i class="fa fa-search fa-3x mb-3 d-block"></i>
                    Không tìm thấy sản phẩm phù hợp.
                </div>
            }
        </div>
    </div>
</div>
