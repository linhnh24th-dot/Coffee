@model List<Product>
@{
    ViewData["Title"] = "Online Store";
}

<!-- Page Header -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container py-5">
        <h1 class="display-3 text-white animated slideInRight">Online Store</h1>
        <nav aria-label="breadcrumb animated slideInRight">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item active">Store</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-xxl py-5">
    <div class="container">
        <div class="section-title text-center mx-auto wow fadeInUp" data-wow-delay="0.1s" style="max-width: 600px;">
            <p class="fs-5 fw-medium fst-italic text-primary">Online Store</p>
            <h1 class="display-6">Muốn không stress ư, ở đây chúng mình còn bán tranh meme "Hoàng Thượng" nữa nè!!!</h1>
        </div>

        <div class="row g-4 mt-2">
            @if (Model != null && Model.Any())
            {
                foreach (var p in Model)
                {
                    <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="store-item position-relative text-center rounded overflow-hidden shadow-sm">
                            <img class="img-fluid w-100" src="~/img/@(p.Image ?? "mew1.png")" alt="@p.Name"
                                 style="height: 280px; object-fit: cover;">
                            <div class="p-4">
                                <div class="text-center mb-2">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        <small class="fa fa-star text-primary"></small>
                                    }
                                </div>
                                <h4 class="mb-2">@p.Name</h4>
                                <p class="text-muted small mb-3">@p.Description</p>
                                <h5 class="text-primary mb-3">@p.Price.ToString("N0") VND</h5>
                                <a asp-area="" asp-controller="Product" asp-action="Details" asp-route-id="@p.Id"
                                   class="btn btn-primary rounded-pill py-2 px-4">
                                    Xem chi tiết <i class="fa fa-arrow-right ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5 text-muted">
                    <i class="fa fa-image fa-3x mb-3 d-block"></i>
                    Chưa có sản phẩm trong Store.
                    Vào Admin → Sản phẩm → Thêm sản phẩm loại "Tranh meme".
                </div>
            }
        </div>
    </div>
</div>
