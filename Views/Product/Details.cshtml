@model Product
@{
    ViewData["Title"] = Model.Name;
}
<div class="container-xxl py-5">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-area="" asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>
        <div class="row g-5">
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.1s">
                <img class="img-fluid rounded w-100" src="~/img/@(Model.Image ?? "cfden.jpg")" alt="@Model.Name">
            </div>
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.3s">
                <h1 class="display-6 mb-2">@Model.Name</h1>
                @if (!string.IsNullOrEmpty(Model.Type))
                {
                    <p class="mb-3"><span class="badge bg-secondary fs-6">@Model.Type</span></p>
                }
                <h3 class="text-primary mb-4">@Model.Price.ToString("N0") VND</h3>
                <p class="mb-4">@Model.Description</p>

                <form asp-area="" asp-controller="Cart" asp-action="Add" method="post">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <div class="d-flex align-items-center gap-3">
                        <input type="number" name="quantity" value="1" min="1" max="99"
                               class="form-control text-center" style="width: 90px;">
                        <button type="submit" class="btn btn-primary rounded-pill py-3 px-5">
                            <i class="fa fa-shopping-cart me-2"></i>Thêm vào giỏ hàng
                        </button>
                    </div>
                </form>
                <a asp-area="" asp-controller="Product" asp-action="Index"
                   class="btn btn-outline-secondary rounded-pill py-2 px-4 mt-3">
                    <i class="fa fa-arrow-left me-2"></i>Xem thêm sản phẩm
                </a>
            </div>
        </div>
    </div>
</div>
