@model List<HyliCoffeeWeb.Services.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
}
<div class="container-xxl py-5">
    <div class="container">
        <h1 class="display-6 mb-4">Giỏ hàng của bạn</h1>

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="fa fa-shopping-cart fa-3x text-muted mb-3 d-block"></i>
                <p class="text-muted fs-5">Giỏ hàng đang trống.</p>
                <a asp-area="" asp-controller="Product" asp-action="Index"
                   class="btn btn-primary rounded-pill px-5 py-3">
                    <i class="fa fa-arrow-left me-2"></i>Tiếp tục mua sắm
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                <div class="col-lg-8">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Đơn giá</th>
                                <th style="width: 150px">Số lượng</th>
                                <th>Thành tiền</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="~/img/@(item.Image ?? "cfden.jpg")" width="60" class="rounded">
                                            <span>@item.Name</span>
                                        </div>
                                    </td>
                                    <td>@item.Price.ToString("N0") VND</td>
                                    <td>
                                        <form asp-area="" asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="d-flex gap-2">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control form-control-sm" style="width: 70px">
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">↺</button>
                                        </form>
                                    </td>
                                    <td class="fw-bold">@item.Total.ToString("N0") VND</td>
                                    <td>
                                        <form asp-area="" asp-controller="Cart" asp-action="Remove" method="post">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-sm btn-danger" title="Xóa">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title mb-4">Tóm tắt đơn hàng</h5>
                            <div class="d-flex justify-content-between mb-3">
                                <span>Tạm tính</span>
                                <span>@Model.Sum(c => c.Total).ToString("N0") VND</span>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <span>Phí giao hàng</span>
                                <span class="text-success">Miễn phí</span>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between mb-4">
                                <strong>Tổng cộng</strong>
                                <strong class="text-primary fs-5">@Model.Sum(c => c.Total).ToString("N0") VND</strong>
                            </div>
                            <a asp-area="" asp-controller="Cart" asp-action="Checkout"
                               class="btn btn-primary rounded-pill w-100 py-3">
                                Tiến hành thanh toán <i class="fa fa-arrow-right ms-2"></i>
                            </a>
                            <a asp-area="" asp-controller="Product" asp-action="Index"
                               class="btn btn-outline-secondary rounded-pill w-100 py-2 mt-2">
                                Tiếp tục mua sắm
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
