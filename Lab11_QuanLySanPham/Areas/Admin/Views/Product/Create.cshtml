@model Product
@{
    ViewData["Title"] = "Thêm sản phẩm";
}
<form asp-area="Admin" asp-controller="Product" asp-action="Create" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Tên sản phẩm</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Giá (VND)</label>
            <input asp-for="Price" class="form-control" type="number" step="1000" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Loại</label>
            <input asp-for="Type" class="form-control" placeholder="VD: Cà phê, Trà, Tranh meme" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Ảnh sản phẩm</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
        </div>
        <div class="col-md-6 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="Featured" class="form-check-input" />
                <label asp-for="Featured" class="form-check-label">Hiển thị nổi bật trên trang chủ</label>
            </div>
        </div>
        <div class="col-12">
            <label class="form-label">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Lưu</button>
            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary">Hủy</a>
        </div>
    </div>
</form>
