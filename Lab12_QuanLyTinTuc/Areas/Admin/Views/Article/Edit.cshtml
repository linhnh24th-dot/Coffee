@model Article
@{
    ViewData["Title"] = "Cập nhật tin tức";
}
<form asp-area="Admin" asp-controller="Article" asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label">Tiêu đề</label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Chuyên mục</label>
            <input asp-for="Category" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Ảnh hiện tại</label><br />
            <img src="~/img/@(Model.Image ?? "article.jpg")" width="100" class="mb-2 d-block" />
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
        </div>
        <div class="col-12">
            <label class="form-label">Nội dung</label>
            <textarea asp-for="Content" class="form-control" rows="8"></textarea>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            <a asp-area="Admin" asp-controller="Article" asp-action="Index" class="btn btn-secondary">Hủy</a>
        </div>
    </div>
</form>
